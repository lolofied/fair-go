# Optional: enable encrypted sync (Supabase, Sydney ap-southeast-2)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: anonymised product analytics (PostHog). Omit in dev to disable.
# Enable cookieless server hash mode in your PostHog project before using this.
# VITE_POSTHOG_KEY=phc_your_project_token
# VITE_POSTHOG_HOST=https://us.i.posthog.com
